# Configuration for the runshot gallery server (`runshot serve`).
#
# To use this file, either export the vars:
#   export $(grep -v '^#' .env | xargs)
# or run with Node's loader:
#   node --env-file=.env gallery.mjs --serve

# Port the server binds. Default: 8080. If the port is busy, runshot fails
# loudly — it never silently falls back to another port.
PORT=8080

# Network interface to bind. 0.0.0.0 = reachable on the LAN; 127.0.0.1 = local
# only (use this behind a reverse proxy like Caddy). Default: 0.0.0.0.
HOST=0.0.0.0

# URL prefix the app is mounted under. "/" (default) = served at the root.
# "/runshot" = every internal link, redirect, asset, and API path lives under
# /runshot (e.g. behind a path-routing proxy like Tailscale Serve).
BASE_PATH=/

# Canonical external URL, INCLUDING the base path. Used for absolute/public
# URLs and logged on startup. Leave as the local URL for dev.
PUBLIC_BASE_URL=http://localhost:8080

# --- Examples for other hosting modes (uncomment one set) ---
#
# Tailscale path mode (https://your-machine.your-tailnet.ts.net/runshot):
#   HOST=0.0.0.0
#   BASE_PATH=/runshot
#   PUBLIC_BASE_URL=https://your-machine.your-tailnet.ts.net/runshot
#
# Caddy subdomain mode (https://runshot.example.com):
#   HOST=127.0.0.1
#   BASE_PATH=/
#   PUBLIC_BASE_URL=https://runshot.example.com
